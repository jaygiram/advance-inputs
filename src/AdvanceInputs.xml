<?xml version="1.0" encoding="utf-8"?>
<widget
    id="threemsoftware.advanceinputs.AdvanceInputs"
    pluginWidget="true"
    needsEntityContext="true"
    offlineCapable="true"
    supportedPlatform="Web"
    xmlns="http://www.mendix.com/widget/1.0/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd"
>
    <name>Advance Inputs</name>

    <description>
        An advanced Mendix input widget with configurable prefix and suffix actions,
        validation, accessibility, and modern UI states.
    </description>

    <icon/>

    <properties>
        <propertyGroup caption="Data">
            <property
                key="valueAttribute"
                type="attribute"
                required="true"
            >
                <caption>Value attribute</caption>

                <description>
                    Select the String attribute used to store the input value.
                </description>

                <attributeTypes>
                    <attributeType name="String"/>
                </attributeTypes>
            </property>

            <property
                key="placeholder"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Placeholder</caption>

                <description>
                    Text displayed when the input has no value.
                </description>
            </property>
        </propertyGroup>

        <propertyGroup caption="Label">
            <property
                key="showLabel"
                type="boolean"
                defaultValue="true"
            >
                <caption>Show label</caption>
            </property>

            <property
                key="labelText"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Label text</caption>
            </property>

            <property
                key="required"
                type="boolean"
                defaultValue="false"
            >
                <caption>Required</caption>
            </property>

            <property
                key="requiredIndicator"
                type="string"
                required="false"
                defaultValue="*"
            >
                <caption>Required indicator</caption>
            </property>
        </propertyGroup>

        <propertyGroup caption="Supporting Text">
            <property
                key="showHelperText"
                type="boolean"
                defaultValue="false"
            >
                <caption>Show helper text</caption>
            </property>

            <property
                key="helperText"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Helper text</caption>
            </property>

            <property
                key="reserveMessageSpace"
                type="boolean"
                defaultValue="false"
            >
                <caption>Reserve message space</caption>
            </property>
        </propertyGroup>

        <propertyGroup caption="Prefix">
            <property
                key="showPrefix"
                type="boolean"
                defaultValue="false"
            >
                <caption>Show prefix</caption>
            </property>

            <property
                key="prefixContentType"
                type="enumeration"
                defaultValue="icon"
            >
                <caption>Prefix content type</caption>
                <enumerationValues>
                    <enumerationValue key="icon">Icon</enumerationValue>
                    <enumerationValue key="text">Text</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="prefixIcon"
                type="icon"
                required="false"
            >
                <caption>Prefix icon</caption>
            </property>

            <property
                key="prefixText"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Prefix text</caption>
            </property>

            <property
                key="prefixAppearance"
                type="enumeration"
                defaultValue="plain"
            >
                <caption>Prefix appearance</caption>
                <enumerationValues>
                    <enumerationValue key="plain">Plain</enumerationValue>
                    <enumerationValue key="soft">Soft</enumerationValue>
                    <enumerationValue key="outlined">Outlined</enumerationValue>
                    <enumerationValue key="filled">Filled</enumerationValue>
                    <enumerationValue key="attached">Attached</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="prefixInteractive"
                type="boolean"
                defaultValue="false"
            >
                <caption>Interactive</caption>
            </property>

            <property
                key="prefixAction"
                type="action"
                required="false"
            >
                <caption>On click</caption>
            </property>

            <property
                key="prefixTooltip"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Tooltip</caption>
            </property>

            <property
                key="prefixAriaLabel"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Accessibility label</caption>
            </property>
        </propertyGroup>

        <propertyGroup caption="Suffix">
            <property
                key="showSuffix"
                type="boolean"
                defaultValue="false"
            >
                <caption>Show suffix</caption>
            </property>

            <property
                key="suffixContentType"
                type="enumeration"
                defaultValue="icon"
            >
                <caption>Suffix content type</caption>
                <enumerationValues>
                    <enumerationValue key="icon">Icon</enumerationValue>
                    <enumerationValue key="text">Text</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="suffixIcon"
                type="icon"
                required="false"
            >
                <caption>Suffix icon</caption>
            </property>

            <property
                key="suffixText"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Suffix text</caption>
            </property>

            <property
                key="suffixAppearance"
                type="enumeration"
                defaultValue="plain"
            >
                <caption>Suffix appearance</caption>
                <enumerationValues>
                    <enumerationValue key="plain">Plain</enumerationValue>
                    <enumerationValue key="soft">Soft</enumerationValue>
                    <enumerationValue key="outlined">Outlined</enumerationValue>
                    <enumerationValue key="filled">Filled</enumerationValue>
                    <enumerationValue key="attached">Attached</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="suffixBehavior"
                type="enumeration"
                defaultValue="custom"
            >
                <caption>Suffix behavior</caption>
                <description>
                    Chooses whether the suffix uses custom content and actions, clears the input, or toggles password visibility. Password toggle is only meaningful when the input type is password.
                </description>
                <enumerationValues>
                    <enumerationValue key="custom">Custom content</enumerationValue>
                    <enumerationValue key="clear">Clear input</enumerationValue>
                    <enumerationValue key="passwordToggle">Show or hide password</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="clearAriaLabel"
                type="string"
                required="false"
                defaultValue="Clear input"
            >
                <caption>Clear button accessibility label</caption>
                <description>
                    Accessible label used for the built-in clear button when clear input behavior is selected.
                </description>
            </property>

            <property
                key="showPasswordAriaLabel"
                type="string"
                required="false"
                defaultValue="Show password"
            >
                <caption>Show password accessibility label</caption>
                <description>
                    Accessible label used when the built-in password toggle shows the password value.
                </description>
            </property>

            <property
                key="hidePasswordAriaLabel"
                type="string"
                required="false"
                defaultValue="Hide password"
            >
                <caption>Hide password accessibility label</caption>
                <description>
                    Accessible label used when the built-in password toggle hides the password value.
                </description>
            </property>

            <property
                key="hideClearWhenEmpty"
                type="boolean"
                defaultValue="true"
            >
                <caption>Hide clear button when empty</caption>
                <description>
                    Hides the built-in clear button when the input value is empty. This only applies to clear input behavior.
                </description>
            </property>

            <property
                key="suffixInteractive"
                type="boolean"
                defaultValue="false"
            >
                <caption>Interactive</caption>
            </property>

            <property
                key="suffixAction"
                type="action"
                required="false"
            >
                <caption>On click</caption>
            </property>

            <property
                key="suffixTooltip"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Tooltip</caption>
            </property>

            <property
                key="suffixAriaLabel"
                type="string"
                required="false"
                defaultValue=""
            >
                <caption>Accessibility label</caption>
            </property>
        </propertyGroup>

        <propertyGroup caption="Input behavior">
            <property
                key="inputType"
                type="enumeration"
                defaultValue="text"
            >
                <caption>Input type</caption>
                <description>
                    Sets the native browser input type so the field can use the appropriate keyboard and validation behavior.
                </description>
                <enumerationValues>
                    <enumerationValue key="text">Text</enumerationValue>
                    <enumerationValue key="password">Password</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="url">URL</enumerationValue>
                    <enumerationValue key="search">Search</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="autocomplete"
                type="enumeration"
                defaultValue="off"
            >
                <caption>Autocomplete</caption>
                <description>
                    Sets the browser autocomplete hint so the input can participate in form autofill and saved-value suggestions.
                </description>
                <enumerationValues>
                    <enumerationValue key="off">Off</enumerationValue>
                    <enumerationValue key="on">On</enumerationValue>
                    <enumerationValue key="name">Name</enumerationValue>
                    <enumerationValue key="given-name">Given name</enumerationValue>
                    <enumerationValue key="family-name">Family name</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="username">Username</enumerationValue>
                    <enumerationValue key="current-password">Current password</enumerationValue>
                    <enumerationValue key="new-password">New password</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="organization">Organization</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="inputMode"
                type="enumeration"
                defaultValue="text"
            >
                <caption>Input mode</caption>
                <description>
                    Sets the browser input mode to influence the virtual keyboard shown on touch devices.
                </description>
                <enumerationValues>
                    <enumerationValue key="text">Text</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="url">URL</enumerationValue>
                    <enumerationValue key="numeric">Numeric</enumerationValue>
                    <enumerationValue key="decimal">Decimal</enumerationValue>
                    <enumerationValue key="search">Search</enumerationValue>
                    <enumerationValue key="none">None</enumerationValue>
                </enumerationValues>
            </property>

            <property
                key="enableMaxLength"
                type="boolean"
                defaultValue="false"
            >
                <caption>Limit maximum length</caption>
                <description>
                    Enables browser-based length validation so the input stops accepting additional characters when the maximum is reached.
                </description>
            </property>

            <property
                key="maxLength"
                type="integer"
                defaultValue="100"
            >
                <caption>Maximum length</caption>
                <description>
                    Sets the maximum number of characters the browser allows when length limiting is enabled.
                </description>
            </property>

   
           

     

            <property
                key="spellCheck"
                type="boolean"
                defaultValue="true"
            >
                <caption>Enable spellcheck</caption>
                <description>
                    Enables or disables browser spell checking for the input value.
                </description>
            </property>

            <property
                key="autoFocus"
                type="boolean"
                defaultValue="false"
            >
                <caption>Autofocus</caption>
                <description>
                    Gives focus to the input automatically when the widget is rendered in the browser.
                </description>
            </property>
        </propertyGroup>
    </properties>
</widget>
