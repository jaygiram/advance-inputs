<?xml version="1.0" encoding="utf-8"?>
<widget id="threemsoftware.advanceinputs.AdvanceInputs" pluginWidget="true" needsEntityContext="true" offlineCapable="true" supportedPlatform="Web"
    xmlns="http://www.mendix.com/widget/1.0/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Advance Inputs</name>

    <description>
        An advanced Mendix input widget with configurable prefix and suffix actions,
        validation, accessibility, and modern UI states.
    </description>

    <icon/>

    <properties>
        <propertyGroup caption="Data">
         <property key="valueAttribute" type="attribute" required="true">
    <caption>Value attribute</caption>
    <description>
        Select the String attribute used to store the input value.
    </description>
    <attributeTypes>
        <attributeType name="String"/>
    </attributeTypes>
    
    <property key="placeholder" type="string" required="false" defaultValue="">
    <caption>Placeholder</caption>
    <description/>
</property>

</property>
        </propertyGroup>

        <propertyGroup caption="Label">
            <property key="showLabel" type="boolean" defaultValue="true">
                <caption>Show label</caption>
                <description/>
            </property>


            <property key="labelText" type="string" required="false" defaultValue="">
                <caption>Label text</caption>
                <description/>
            </property>

            <property key="inputTooltip" type="string" required="false" defaultValue="">
                <caption>Input tooltip</caption>
                <description>
  This tooltip belongs to the input and not to the label.
                </description>
            </property>
            <property key="required" type="boolean" defaultValue="false">
                <caption>Required</caption>
                <description/>
            </property>

            <property key="requiredIndicator" type="string" required="false" defaultValue="*">
                <caption>Required indicator</caption>
                <description/>
            </property>
        </propertyGroup>

        <propertyGroup caption="Supporting Text">
            <property key="showHelperText" type="boolean" defaultValue="false">
                <caption>Show helper text</caption>
                <description/>
            </property>

            <property key="helperText" type="string" required="false" defaultValue="">
                <caption>Helper text</caption>
                <description/>
            </property>

            <property key="reserveMessageSpace" type="boolean" defaultValue="false">
                <caption>Reserve message space</caption>
                <description/>
            </property>
        </propertyGroup>

        <propertyGroup caption="Prefix">
            <property key="showPrefix" type="boolean" defaultValue="false">
                <caption>Show prefix</caption>
                <description/>
            </property>

            <property key="prefixContentType" type="enumeration" defaultValue="icon">
                <caption>Prefix content type</caption>
                <description/>
                <enumerationValues>
                    <enumerationValue key="icon">Icon</enumerationValue>
                    <enumerationValue key="text">Text</enumerationValue>
                </enumerationValues>
            </property>

            <property key="prefixIcon" type="icon" required="false">
                <caption>Prefix icon</caption>
                <description/>
            </property>

            <property key="prefixText" type="string" required="false" defaultValue="">
                <caption>Prefix text</caption>
                <description/>
            </property>



      <property key="prefixShowAsButton" type="boolean" defaultValue="false">
    <caption>Show as button</caption>
    <description/>
</property>

            <property key="prefixButtonBackgroundColor" type="string" required="false" defaultValue="">
                <caption>Button background color</caption>
V    <description/>
            </property>

   <property key="prefixButtonIconColor" type="string" required="false" defaultValue="">
    <caption>Button icon color</caption>
    <description/>
</property>
            <property key="prefixInteractive" type="boolean" defaultValue="false">
                <caption>Interactive</caption>
                <description/>
            </property>

            <property key="prefixAction" type="action" required="false">
                <caption>On click</caption>
                <description/>
            </property>

            <property key="prefixTooltip" type="string" required="false" defaultValue="">
                <caption>Tooltip</caption>
                <description/>
            </property>

            <property key="prefixAriaLabel" type="string" required="false" defaultValue="">
                <caption>Accessibility label</caption>
                <description/>
            </property>
        </propertyGroup>

        <propertyGroup caption="Suffix">

            <property key="showSuffix" type="boolean" defaultValue="false">
                <caption>Show suffix</caption>
                <description/>
            </property>

            <property key="suffixContentType" type="enumeration" defaultValue="icon">
                <caption>Suffix content type</caption>
                <description/>
                <enumerationValues>
                    <enumerationValue key="icon">Icon</enumerationValue>
                    <enumerationValue key="text">Text</enumerationValue>
                </enumerationValues>
            </property>

            <property key="suffixIcon" type="icon" required="false">
                <caption>Suffix icon</caption>
                <description/>
            </property>

            <property key="suffixText" type="string" required="false" defaultValue="">
                <caption>Suffix text</caption>
                <description/>
            </property>
<property key="suffixButtonBackgroundColor" type="string" required="false" defaultValue="">
    <caption>Button background color</caption>
    <description/>
</property>

           <property key="suffixButtonIconColor" type="string" required="false" defaultValue="">
    <caption>Button icon color</caption>
    <description/>
</property>

            <property key="suffixButtonIconColor" type="string" required="false" defaultValue="">
                <caption>Button icon color</caption>
    <description/>
            </property>

            <property key="suffixInteraction" type="enumeration" defaultValue="none">
                <caption>Interaction</caption>
                <description>Select the built-in or custom suffix interaction.</description>
                <enumerationValues>
                    <enumerationValue key="none">None</enumerationValue>
                    <enumerationValue key="action">Action</enumerationValue>
                    <enumerationValue key="clear">Clear input</enumerationValue>
                    <enumerationValue key="passwordToggle">Password toggle</enumerationValue>
                    <enumerationValue key="copyText">Copy text</enumerationValue>
                </enumerationValues>
            </property>


            <property key="suffixAction" type="action" required="false">
                <caption>On click</caption>
                <description>
        Mendix action executed when Interaction is set to Action.
                </description>
            </property>

            <property key="suffixTooltip" type="string" required="false" defaultValue="">
                <caption>Tooltip</caption>
                <description/>
            </property>

            <property key="suffixAriaLabel" type="string" required="false" defaultValue="">
                <caption>Accessibility label</caption>
                <description/>
            </property>
        </propertyGroup>

        <propertyGroup caption="Input behavior">
            <property key="inputType" type="enumeration" defaultValue="text">
                <caption>Input type</caption>
                <description>
                    Sets the native browser input type so the field can use the appropriate keyboard and validation behavior.
                </description>
                <enumerationValues>
                    <enumerationValue key="text">Text</enumerationValue>
                    <enumerationValue key="password">Password</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="url">URL</enumerationValue>
                    <enumerationValue key="search">Search</enumerationValue>
                </enumerationValues>
            </property>

            <property key="autocomplete" type="enumeration" defaultValue="off">
                <caption>Autocomplete</caption>
                <description>
        Sets the browser autocomplete hint so the input can participate in form autofill and saved-value suggestions.
                </description>

                <enumerationValues>
                    <enumerationValue key="off">Off</enumerationValue>
                    <enumerationValue key="on">On</enumerationValue>
                    <enumerationValue key="name">Name</enumerationValue>
                    <enumerationValue key="givenName">Given name</enumerationValue>
                    <enumerationValue key="familyName">Family name</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="username">Username</enumerationValue>
                    <enumerationValue key="currentPassword">Current password</enumerationValue>
                    <enumerationValue key="newPassword">New password</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="organization">Organization</enumerationValue>
                </enumerationValues>
            </property>

            <property key="inputMode" type="enumeration" defaultValue="text">
                <caption>Input mode</caption>
                <description>
                    Sets the browser input mode to influence the virtual keyboard shown on touch devices.
                </description>
                <enumerationValues>
                    <enumerationValue key="text">Text</enumerationValue>
                    <enumerationValue key="email">Email</enumerationValue>
                    <enumerationValue key="tel">Telephone</enumerationValue>
                    <enumerationValue key="url">URL</enumerationValue>
                    <enumerationValue key="numeric">Numeric</enumerationValue>
                    <enumerationValue key="decimal">Decimal</enumerationValue>
                    <enumerationValue key="search">Search</enumerationValue>
                    <enumerationValue key="none">None</enumerationValue>
                </enumerationValues>
            </property>
            <property key="enableInputMask" type="boolean" defaultValue="false">
                <caption>Enable input mask</caption>
                <description>
        Formats and restricts the entered value using a predefined or custom input mask.
                </description>
            </property>

            <property key="inputMaskType" type="enumeration" defaultValue="phone">
                <caption>Mask type</caption>
                <description>
        Select a predefined input mask or define a custom mask.
                </description>

                <enumerationValues>
                    <enumerationValue key="date">Date</enumerationValue>
                    <enumerationValue key="phone">Phone number</enumerationValue>
                    <enumerationValue key="pan">PAN</enumerationValue>
                    <enumerationValue key="gst">GST number</enumerationValue>
                    <enumerationValue key="ssn">SSN</enumerationValue>
                    <enumerationValue key="custom">Custom mask</enumerationValue>
                </enumerationValues>
            </property>

            <property key="dateMaskFormat" type="enumeration" defaultValue="ddMMyyyy">
                <caption>Date format</caption>
                <description>
        Select the display format used by the Date mask.
                </description>

                <enumerationValues>
                    <enumerationValue key="ddMMyyyy">DD/MM/YYYY</enumerationValue>
                    <enumerationValue key="MMddyyyy">MM/DD/YYYY</enumerationValue>
                    <enumerationValue key="yyyyMMdd">YYYY-MM-DD</enumerationValue>
                </enumerationValues>
            </property>

            <property key="phoneMaskFormat" type="enumeration" defaultValue="india">
                <caption>Phone format</caption>
                <description>
        Select the predefined phone-number format.
                </description>

                <enumerationValues>
                    <enumerationValue key="india">India (+91)</enumerationValue>
                    <enumerationValue key="us">United States</enumerationValue>
                    <enumerationValue key="international">International</enumerationValue>
                </enumerationValues>
            </property>

            <property key="customInputMask" type="string" required="false" defaultValue="">
                <caption>Custom mask</caption>
                <description>
        Define a custom pattern. Use 0 for a required digit, a for a required letter and * for a required alphanumeric character. Example: AAA-0000 is not supported; use aaa-0000.
                </description>
            </property>

            <property key="inputMaskPlaceholderCharacter" type="string" required="false" defaultValue="_">
                <caption>Placeholder character</caption>
                <description>
        Character displayed for incomplete positions in the mask.
                </description>
            </property>

            <property key="showInputMaskPlaceholder" type="boolean" defaultValue="false">
                <caption>Show mask placeholder</caption>
                <description>
        Displays the remaining mask positions while the input is focused.
                </description>
            </property>

            <property key="storeUnmaskedValue" type="boolean" defaultValue="false">
                <caption>Store unmasked value</caption>
                <description>
        Stores only the underlying characters in the Mendix attribute instead of the formatted display value.
                </description>
            </property>
    <property
    key="validationType"
    type="enumeration"
    defaultValue="none"
>
    <caption>Input validation</caption>

    <description>
        Validates the entered text before storing it in the selected Mendix String attribute.
    </description>

    <enumerationValues>
        <enumerationValue key="none">No additional validation</enumerationValue>
        <enumerationValue key="numeric">Numbers only</enumerationValue>
        <enumerationValue key="decimal">Decimal number</enumerationValue>
        <enumerationValue key="custom">Custom pattern</enumerationValue>
    </enumerationValues>
</property>

<property
    key="customPattern"
    type="string"
    required="false"
    defaultValue=""
>
    <caption>Custom pattern</caption>

    <description>
        Regular expression used when Input validation is set to Custom pattern. Enter the expression without surrounding slash characters.
    </description>
</property>

<property
    key="validationMessage"
    type="string"
    required="false"
    defaultValue=""
>
    <caption>Validation message</caption>

    <description>
        Message shown when custom pattern validation fails.
    </description>
</property>

<property
    key="enableMaxLength"
    type="boolean"
    defaultValue="false"
>
    <caption>Limit maximum length</caption>

    <description>
        Enables maximum-length validation for the input.
    </description>
</property>

<property
    key="maxLength"
    type="integer"
    defaultValue="200"
>
    <caption>Maximum length</caption>

    <description>
        Sets the maximum number of characters allowed when length limiting is enabled.
    </description>
</property>

<property
    key="showCharacterCounter"
    type="boolean"
    defaultValue="false"
>
    <caption>Show character counter</caption>

    <description>
        Displays the current number of entered characters together with the configured maximum length.
    </description>
</property>

            <property key="spellCheck" type="boolean" defaultValue="true">
                <caption>Enable spellcheck</caption>
                <description>
        Enables or disables browser spell checking for the input value.
                </description>
            </property>

            <property key="autoFocus" type="boolean" defaultValue="false">
                <caption>Autofocus</caption>
                <description>
        Gives focus to the input automatically when the widget is rendered in the browser.
                </description>
            </property>
        </propertyGroup>
    </properties>
</widget>
